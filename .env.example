# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# Use these variables in Render dashboard for deployment

# Database Configuration (Render PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/FoodSecDB
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=root

# JPA Configuration
JPA_DDL_AUTO=update
JPA_FORMAT_SQL=true
JPA_SHOW_SQL=true

# JWT Configuration
JWT_SECRET=mySecretKeyForJWT123456789012345678901234567890
JWT_EXPIRATION=86400

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Server Configuration
SERVER_PORT=8080

# Email Configuration (Gmail SMTP)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=amit276075@gmail.com
SPRING_MAIL_PASSWORD=apbi xdrw hwpt xyrv
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Frontend Configuration
APP_FRONTEND_URL=http://localhost:3000

# Render-specific variables (set these in Render dashboard)
# DATABASE_URL=postgresql://username:password@host:port/database
# JWT_SECRET=your-secure-jwt-secret-key
# SPRING_MAIL_USERNAME=your-gmail-address
# SPRING_MAIL_PASSWORD=your-gmail-app-password
# APP_FRONTEND_URL=https://your-frontend-app-name.onrender.com
